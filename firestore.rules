rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return request.auth != null && getUserRole() == 'admin'; }
    function isTeacher() { return request.auth != null && getUserRole() == 'teacher'; }
    function isStudent() { return request.auth != null && getUserRole() == 'student'; }
    function isOwner(userId) { return request.auth != null && request.auth.uid == userId; }

    match /usuarios/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'student';
      allow delete: if isAdmin();
      match /enrollments/{enrollmentId} {
        allow read: if isOwner(userId) || isAdmin() || isTeacher();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
      match /progress/{lessonId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /badges/{badgeId} {
        allow read: if isOwner(userId) || isAdmin() || isTeacher();
        allow create: if isAdmin() || (isTeacher() && request.resource.data.earnedBy == userId);
        allow delete: if isAdmin();
      }
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if request.auth != null;
      }
    }

    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin() || (isTeacher() && resource.data.instructorId == request.auth.uid);
      allow delete: if isAdmin();
      match /lessons/{lessonId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || (isTeacher() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
      match /lessons/{lessonId}/tests/{testId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || isTeacher();
      }
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null &&
        (resource.data.status == 'published' || isAdmin() || isTeacher()) &&
        (resource.data.visibility == 'public' || isAdmin() || isTeacher() || (isStudent() && request.auth.uid in resource.data.assignedStudents));
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /submissions/{submissionId} {
      allow read: if request.auth != null && (
        isOwner(resource.data.studentId) || isAdmin() || 
        (isTeacher() && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.teacherId == request.auth.uid)
      );
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || (isTeacher() && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /comentarios/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    match /materias/{materiaId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || isTeacher();
      allow delete: if isAdmin() || (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    match /chat/{materiaId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
    match /courses/{courseId}/{fileId} {
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.role in ['admin', 'teacher'];
    }
    match /submissions/{userId}/{taskId}/{fileName} {
      allow write: if request.auth.uid == userId;
      allow read: if request.auth.uid == userId || 
        get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.role in ['teacher', 'admin'];
    }
    match /logos/{fileName} {
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow read: if request.auth != null;
    }
    match /users/{userId}/{fileId} {
      allow write: if request.auth.uid == userId;
      allow read: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}